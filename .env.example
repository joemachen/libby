# Path to the folder containing your EPUB files
LIBRARY_PATH=C:\Users\YourName\Books

# Where the SQLite DB and extracted covers are stored (relative to project root)
DATA_PATH=./data

# Subfolder on the Kobo device to copy books into — leave blank to use device root
KOBO_BOOKS_FOLDER=

# Flask server port
PORT=5000

# Enable Flask debug mode (true/false) — keep false in normal use
DEBUG=false
